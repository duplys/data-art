{
  "name": "data-art-web",
  "version": "0.1.0",
  "description": "Transform text into visual data art — web application",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
